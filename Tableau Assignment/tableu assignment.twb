      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1vlmv8j0b75dgg1h7f7s21f1fo1g].[pcto:sum:Profit:qk:2]&quot;' value='profit %' />
          <alias key='&quot;[federated.1vlmv8j0b75dgg1h7f7s21f1fo1g].[pcto:sum:Sales:qk:2]&quot;' value=' sales %' />
        </aliases>
      </column>
      <column caption='customer grouping' datatype='string' name='[Calculation_1196550149307293696]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [top 50N customers] THEN &quot;Top 50 Customers&quot; ELSE &quot;Others&quot; END' />
      </column>
      <column caption='cy profit' datatype='real' default-format='c&quot;$&quot;#,##0,.00K' name='[Calculation_1196550149316141059]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF  YEAR([Order Date]) = {MAX(YEAR([Order Date]))} THEN [Profit] END' />
      </column>
      <column caption='py profit' datatype='real' name='[Calculation_1196550149316378628]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = {MAX(YEAR([Order Date]))} - 1 THEN [Profit] END' />
      </column>
      <column caption='profit growth %' datatype='real' name='[Calculation_1196550149316485125]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_1196550149316141059]) - SUM([Calculation_1196550149316378628])) / SUM([Calculation_1196550149316378628])' />
      </column>
      <column caption='Growth icon' datatype='string' name='[Calculation_1196550149317115910]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1196550149316485125] &gt; 0 THEN &quot;▲ +&quot; ELSEIF [Calculation_1196550149316485125] &lt; 0 THEN &quot;▼ &quot; ELSE &quot;&quot; END' />
      </column>
      <column caption='order per customer' datatype='integer' name='[Calculation_860187549223632897]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED[Customer Name]:COUNTD([Order ID])}' />
      </column>
      <column caption='selected dimension' datatype='string' name='[Calculation_860187549250252808]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Region&quot; THEN [Region]&#13;&#10;WHEN &quot;Category&quot; THEN [Category]&#13;&#10;when &quot;Sub-Category&quot; THEN [Sub-Category]&#13;&#10;END' />
      </column>
      <column caption='Dynamic calculated field' datatype='real' name='[Calculation_860187549281914889]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2] &#13;&#10;WHEN &quot;sales&quot; THEN SUM([Sales])&#13;&#10;when &quot;profit&quot; THEN SUM([Profit])&#13;&#10;when &quot;# orders&quot; THEN COUNTD([Order ID])&#13;&#10;END' />
      </column>
      <column caption='profit margin %' datatype='real' default-format='p0.00%' name='[Calculation_860187549298327564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Return rate %' datatype='real' name='[Calculation_860187549299011597]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Order ID (Returns)])/COUNTD([Order ID])' />
